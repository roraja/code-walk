{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Code Walk: UI Dev Server",
      "detail": "Serve the sidebar UI in a browser with mock data + hot reload (no extension reinstall).",
      "type": "shell",
      "command": "npm run dev:ui",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": [
          {
            "regexp": "^\\s*(✘|error):\\s+(.*)$",
            "severity": 1,
            "message": 2
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "UI dev server"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "Code Walk: Build",
      "detail": "Type-check and bundle the extension + webview.",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Code Walk: Watch",
      "detail": "Rebuild the extension + webview bundles on change.",
      "type": "shell",
      "command": "npm run watch",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    }
  ]
}
